# CoverBuild RL — Environment Variables
# Copy this file to .env and adjust as needed.

# ─── UTF-8 output (required on Windows) ──────────────────────────────────────
PYTHONUTF8=1

# ─── HuggingFace token (required for Gemma — accept license at hf.co/google/gemma-3-1b-it first) ───
# HUGGING_FACE_HUB_TOKEN=hf_your_token_here

# ─── Model paths (override defaults) ─────────────────────────────────────────
# POLICY_MODEL_PATH=./models/ppo/final
# SFT_MODEL_PATH=./models/sft
# REWARD_MODEL_PATH=./models/reward

# ─── MLflow ───────────────────────────────────────────────────────────────────
# MLFLOW_TRACKING_URI=http://localhost:5000
# MLFLOW_EXPERIMENT_NAME=coverbuild

# ─── API ─────────────────────────────────────────────────────────────────────
# API_HOST=0.0.0.0
# API_PORT=8000
